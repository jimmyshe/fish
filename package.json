{
  "name": "fish-pet",
  "version": "1.3.1",
  "description": "A desktop pet that reminds you when to get off work",
  "main": "./out/main/index.js",
  "author": "jimmyshe",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jimmyshe/fish.git"
  },
  "build": {
    "appId": "com.fish.pet",
    "productName": "fish-pet",
    "directories": {
      "output": "dist_electron"
    },
    "win": {
      "target": [
        "nsis",
        "zip"
      ]
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Utility"
    }
  },
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "dist": "electron-vite build && electron-builder"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.1",
    "@electron-toolkit/utils": "^3.0.0",
    "vue": "^3.4.0"
  },
  "devDependencies": {
    "@electron-toolkit/tsconfig": "^1.0.1",
    "@types/node": "^20.14.0",
    "@vitejs/plugin-vue": "^5.0.5",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3",
    "electron-vite": "^2.3.0",
    "typescript": "^5.4.5",
    "vite": "^5.3.1",
    "vue-tsc": "^2.0.21"
  }
}
